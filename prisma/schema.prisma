generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String
  role        String    @default("editor")
  createdAt   DateTime  @default(now())
  createdBy   String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
}

model CourseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(6)

  courses   Course[]
}

model Course {
  id               String        @id @default(cuid())

  title            String
  slug             String        @unique

  description      String
  shortDescription String

  thumbnail        String?
  bannerImage      String?

  // OLD CATEGORY (keep for now)
  category         String

  // NEW CATEGORY SYSTEM
  categoryId       String?

 categoryRef       CourseCategory? @relation(fields: [categoryId], references: [id])

  classRange       String?

  isFeatured       Boolean       @default(false)
  isActive         Boolean       @default(true)

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  boards           CourseBoard[]
  courseInfo       CourseInfo[]
  modes            CourseMode[]
  enrollments      Enrollment[]
  faqs             FAQ[]
  orders           Order[]
}

model CourseBoard {
  id       String @id @default(cuid())
  board    String
  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  @@index([courseId])
}

model CourseMode {
  id          String          @id @default(cuid())
  modeName    String
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  courseId    String
  course      Course          @relation(fields: [courseId], references: [id])
  packages    CoursePackage[]
  enrollments Enrollment[]
  orders      Order[]

  @@index([courseId])
}

model CoursePackage {
  id            String           @id @default(cuid())
  packageName   String
  duration      String?
  description   String?
  isPopular     Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  modeId        String
  isRecommended Boolean          @default(false)
  monthlyPrice  Float
  mode          CourseMode       @relation(fields: [modeId], references: [id])
  enrollments   Enrollment[]
  orders        Order[]
  features      PackageFeature[]

  @@index([modeId])
}

model CourseInfo {
  id        String   @id @default(cuid())
  label     String
  value     String
  sortOrder Int      @default(0)
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])

  @@index([courseId])
}

model PackageFeature {
  id        String        @id @default(cuid())
  feature   String
  packageId String
  package   CoursePackage @relation(fields: [packageId], references: [id])

  @@index([packageId])
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String
  city      String
  phone     String
  mapUrl    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Faculty {
  id         String   @id @default(cuid())
  name       String
  bio        String
  photo      String?
  experience String
  subjects   String[]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  coverImage  String?
  excerpt     String?
  publishedAt DateTime?
}

model Lead {
  id                String   @id @default(cuid())
  name              String
  email             String
  phone             String
  courseInterest    String?
  branch            String?
  source            String?
  status            String   @default("new")
  createdAt         DateTime @default(now())
  leadType          String?
  preferredMode     String?
  referralCode      String?
  schoolCollegeName String?
  studentCategory   String?
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String
  phone       String?
  password    String
  createdAt   DateTime     @default(now())
  enrollments Enrollment[]
  orders      Order[]
}

model Order {
  id                String        @id @default(cuid())
  userId            String
  courseId          String
  amount            Float
  razorpayOrderId   String?
  createdAt         DateTime      @default(now())
  courseModeId      String
  packageId         String
  razorpayPaymentId String?
  status            OrderStatus   @default(pending)
  enrollments       Enrollment[]
  course            Course        @relation(fields: [courseId], references: [id])
  courseMode        CourseMode    @relation(fields: [courseModeId], references: [id])
  package           CoursePackage @relation(fields: [packageId], references: [id])
  user              User          @relation(fields: [userId], references: [id])
}

model Enrollment {
  id               String        @id @default(cuid())
  userId           String
  courseId         String
  createdAt        DateTime      @default(now())
  accessStatus     AccessStatus  @default(pending)
  courseModeId     String
  enrolledAt       DateTime      @default(now())
  lmsAccessGranted Boolean       @default(false)
  orderId          String?
  packageId        String
  course           Course        @relation(fields: [courseId], references: [id])
  courseMode       CourseMode    @relation(fields: [courseModeId], references: [id])
  order            Order?        @relation(fields: [orderId], references: [id])
  package          CoursePackage @relation(fields: [packageId], references: [id])
  user             User          @relation(fields: [userId], references: [id])
  lmsAccess        LMSAccess?

  @@unique([userId, packageId])
}

model LMSAccess {
  id                String       @id @default(cuid())
  enrollmentId      String       @unique
  externalStudentId String?
  accessStatus      AccessStatus @default(pending)
  grantedAt         DateTime?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  enrollment        Enrollment   @relation(fields: [enrollmentId], references: [id])
}

model Result {
  id          String   @id @default(cuid())
  studentName String
  photo       String?
  year        String
  achievement String?
  createdAt   DateTime @default(now())
  examType    String
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  result      String
}

model Testimonial {
  id          String   @id @default(cuid())
  studentName String
  photo       String?
  quote       String
  course      String
  branch      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  courseId  String?
  createdAt DateTime @default(now())
  course    Course?  @relation(fields: [courseId], references: [id])
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  message   String
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  rating    Int
  message   String?
  name      String?
  createdAt DateTime @default(now())
}

enum OrderStatus {
  pending
  paid
  failed
  refunded
}

enum AccessStatus {
  pending
  granted
  revoked
  failed
}
